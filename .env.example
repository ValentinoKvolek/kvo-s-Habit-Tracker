# Database — get these from your Neon project dashboard
DATABASE_URL=postgresql://user:password@host.neon.tech/neondb?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@host.neon.tech/neondb?sslmode=require

# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-here
BETTER_AUTH_URL=http://localhost:3000

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Web Push (PWA notifications) — generate with: node -e "const wp=require('web-push'); console.log(JSON.stringify(wp.generateVAPIDKeys()))"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_CONTACT_EMAIL=your-email@example.com

# Cron secret — protects /api/push/send from public access
CRON_SECRET=your-cron-secret-here

# OAuth (optional — configure in Phase 2)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
